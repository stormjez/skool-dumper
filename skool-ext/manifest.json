{
  "manifest_version": 3,
  "name": "Skool Dumper",
  "version": "1.0",
  "description": "Scarica video da Skool automaticamente",
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.skool.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.skool.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
